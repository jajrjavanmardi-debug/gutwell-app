# Supabase — Expo requires EXPO_PUBLIC_ prefix for values used in the app bundle.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-public-key

# Alias (same value as anon key); supported if you prefer this name:
# EXPO_PUBLIC_SUPABASE_KEY=eyJ...

# Sentry (optional in dev)
EXPO_PUBLIC_SENTRY_DSN=

# USDA API Key
EXPO_PUBLIC_USDA_API_KEY=your-usda-api-key

# Groq API Key
EXPO_PUBLIC_GROQ_API_KEY=your-groq-api-key

# Dev only: skip GPS and pin AI location (e.g. Germany → Nürtingen). Leave unset in production.
# EXPO_PUBLIC_DEV_LOCATION_OVERRIDE=Germany
