# Supabase
EXPO_PUBLIC_SUPABASE_URL=sb_publishable_rhU9lx9AZJmgVhx4RgAWjg_HY8_mYVT
EXPO_PUBLIC_SUPABASE_KEY=your-anon-public-key

# Sentry (optional in dev)
EXPO_PUBLIC_SENTRY_DSN=

# RevenueCat (in-app subscriptions). OPTIONAL: when this is unset, monetization
# is a silent no-op and every user is treated as NON-premium (purchases/restore
# are disabled, premium features stay locked). Going live requires:
#   1. Real auto-renewable subscription products in App Store Connect.
#   2. A RevenueCat project with a "premium" entitlement and a "current" offering
#      whose packages map to those App Store products.
#   3. The RevenueCat iOS *public* SDK key (Project Settings → API keys, the
#      "Apple App Store" key, starts with "appl_"). Safe to ship in the client.
# react-native-purchases is a NATIVE module, so a dev-client / EAS rebuild is
# required (it does NOT work in Expo Go).
EXPO_PUBLIC_REVENUECAT_IOS_KEY=

# PostHog product analytics (optional). When EXPO_PUBLIC_POSTHOG_KEY is unset,
# analytics is a silent no-op. Use the PROJECT API key (safe to ship in clients),
# not a personal API key. HOST defaults to https://us.i.posthog.com (use
# https://eu.i.posthog.com for EU cloud, or your self-hosted URL).
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# -----------------------------------------------------------------------------
# AI / nutrition provider keys are SERVER-SIDE SECRETS.
#
# SECURITY: Do NOT add EXPO_PUBLIC_GROQ_API_KEY / EXPO_PUBLIC_USDA_API_KEY here
# (or anywhere in the client). Anything prefixed EXPO_PUBLIC_ is inlined into the
# JS bundle and is extractable from the shipped IPA/APK -> billing abuse.
#
# All AI + USDA calls now run inside the `analyze-food` Supabase edge function.
# Set these as Supabase secrets instead (never in this file):
#   supabase secrets set GEMINI_API_KEY=...   # vision + text analysis (required)
#   supabase secrets set USDA_API_KEY=...      # USDA FoodData Central (home plan foods)
# Then redeploy: supabase functions deploy analyze-food
# -----------------------------------------------------------------------------

# Dev only: skip GPS and pin AI location (e.g. Germany → Nürtingen). Leave unset in production.
# EXPO_PUBLIC_DEV_LOCATION_OVERRIDE=Germany
