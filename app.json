{
  "expo": {
    "name": "GutWell",
    "slug": "gutwell",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gutwellapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.parallellabs.gutwell",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "GutWell uses your photo library to let you attach photos to your food logs.",
        "NSCameraUsageDescription": "GutWell uses your camera to let you photograph meals for your food log.",
        "NSUserNotificationsUsageDescription": "GutWell uses notifications to remind you to log your daily check-ins and meals."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png",
        "backgroundColor": "#1B4332"
      },
      "package": "com.parallellabs.gutwell",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#1B4332",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "GutWell uses your photo library to let you attach photos to your food logs.",
          "cameraPermission": "GutWell uses your camera to let you photograph meals for your food log."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FAFDF7",
          "dark": {
            "backgroundColor": "#0D2218"
          }
        }
      ],
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
