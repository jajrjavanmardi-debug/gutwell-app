{
  "expo": {
    "name": "GutWell",
    "slug": "gutwell-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gutwellapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.gutwell.ios",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "GutWell uses your photo library to let you attach photos to your food logs.",
        "NSCameraUsageDescription": "GutWell uses your camera to let you photograph meals for your food log.",
        "NSUserNotificationsUsageDescription": "GutWell uses notifications to remind you to log your daily check-ins and meals."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#4A9D6E",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "GutWell uses your photo library to let you attach photos to your food logs.",
          "cameraPermission": "GutWell uses your camera to let you photograph meals for your food log."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F5FAF7",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
